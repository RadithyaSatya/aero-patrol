# Aero Patrol frontend environment example
#
# Copy this file to `.env` or `.env.local`, then adjust the values
# to match the target backend, streams, SSO portal, and geofence setup.

# -----------------------------------------------------------------------------
# API and realtime backend
# -----------------------------------------------------------------------------

# Base HTTP API used by auth, user profile, mission, history, and telemetry REST requests.
# Example: http://localhost:8000 or https://api.example.com
VITE_API_BASE_URL=http://api-xflight.kumalabs.tech

# Base WebSocket endpoint used to connect telemetry/gimbal/camera realtime updates.
# Example: ws://localhost:8000 or wss://api.example.com
VITE_WS_BASE_URL=ws://api-xflight.kumalabs.tech


# -----------------------------------------------------------------------------
# Video streams
# -----------------------------------------------------------------------------

# Primary drone stream URL shown in live video / dashboard panels.
# Leave empty if the drone stream is injected from another source.
VITE_DRONE_STREAM_URL=

# Dock camera / CCTV stream URL shown in the Dock Cam panel.
VITE_DOCK_CCTV_STREAM_URL=

# Optional stream authentication username.
# Fill this if the stream server requires basic/app-level auth.
VITE_STREAM_AUTH_USER=

# Optional stream authentication password.
VITE_STREAM_AUTH_PASS=


# -----------------------------------------------------------------------------
# SSO / portal integration
# -----------------------------------------------------------------------------

# Portal URL used by "Back to Portal" navigation and default SSO logout redirect fallback.
VITE_PORTAL_URL=https://sso.connectmesh.io

# SSO provider logout endpoint called when user logs out from an SSO session.
VITE_SSO_LOGOUT_URL=https://sso-oauth.connectmesh.io/v1/auth/logout

# Redirect target after frontend clears local auth and completes SSO logout flow.
# Recommended: send this to the portal or another landing page, not `/login`.
VITE_SSO_LOGOUT_REDIRECT_URL=https://sso.connectmesh.io

# If true, SSO logout requests add `?all=true` and revoke all user SSO sessions/tokens.
# Usually keep this false unless global logout is really intended.
VITE_SSO_LOGOUT_ALL=false


# -----------------------------------------------------------------------------
# Mission scheduling helpers
# -----------------------------------------------------------------------------

# Offset in minutes for "run now" mission mode.
# Example: 2 means "now" is scheduled 2 minutes after current time.
VITE_MISSION_NOW_OFFSET_MINUTES=2


# -----------------------------------------------------------------------------
# Geofence data source
# -----------------------------------------------------------------------------

# Enable or disable drawing geofence GeoJSON overlays in the map.
# true  = use the selected geofence file
# false = do not render GeoJSON geofence overlay
VITE_GEOFENCE_JSON_ENABLED=true

# Geofence file to load.
# Supported values:
# - geofence.json                    -> legacy default file in src/services/geofence.json
# - sample-rectangle.json           -> example file in src/services/geofences/
# - sample-tight.json               -> example file in src/services/geofences/
#
# To add more choices, place additional `.json` files inside:
#   src/services/geofences/
# then set this variable to that file name.
VITE_GEOFENCE_FILE=geofence.json
